{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Melper",
  "logo": "/public/logo.png",
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#E64566",
    "light": "#f07183",
    "dark": "#E64566",
    "anchors": {
      "from": "#E64566",
      "to": "#f07183"
    },
    "background": {
      "dark": "#121113"
    }
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": true
  },
  "topbarCtaButton": {
    "type": "github",
    "url": "https://github.com/meluiz/melper"
  },
  "anchors": [
    {
      "name": "GitHub",
      "icon": "github",
      "color": "#E64566",
      "url": "https://github.com/meluiz/melper"
    }
  ],
  "navigation": [
    {
      "group": "Overview",
      "pages": ["docs/introduction", "docs/changelog", "docs/roadmap"]
    },
    {
      "group": "Getting Started",
      "pages": [
        "docs/getting-started/installation",
        "docs/getting-started/usage"
      ]
    }
  ],
  "footerSocials": {
    "github": "https://github.com/meluiz/melper"
  }
}
